APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_MODE=live
LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_PORT = 6005
BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
QUEUE_CONNECTION=redis
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=test
PUSHER_APP_KEY=test
PUSHER_APP_SECRET=test
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

HEADER_API_KEY=
ERC20_NODE_URL=

LOG_PRINT_ENABLE=0
DETAILS_LOG_PRINT_ENABLE=0

# =============================================================================
# OBXCoin — Blockchain / On-Chain Settings
# =============================================================================
# BEP-20 / EVM RPC
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545/
ETH_RPC_URL=https://eth.llamarpc.com
POLYGON_RPC_URL=https://polygon-rpc.com
# Chain ID: 56=BSC Mainnet, 97=BSC Testnet, 1=Ethereum, 137=Polygon
PRESALE_CHAIN_ID=56

# Deployed contract addresses (fill after running deploy scripts)
OBX_TOKEN_CONTRACT=
PRESALE_CONTRACT=

# Chain-specific presale addresses (recommended)
PRESALE_CONTRACT_BSC=
PRESALE_CONTRACT_BSC_TEST=
PRESALE_CONTRACT_ETH=
PRESALE_CONTRACT_POLYGON=

# OBXToken address per chain (allows multichain — set whichever chains you deploy to)
OBX_TOKEN_BSC=
OBX_TOKEN_BSC_TEST=
OBX_TOKEN_ETH=
OBX_TOKEN_POLYGON=

# Optional OBX ecosystem addresses by chain
AIRDROP_CONTRACT_BSC=
AIRDROP_CONTRACT_BSC_TEST=
AIRDROP_CONTRACT_ETH=
AIRDROP_CONTRACT_POLYGON=

STAKING_CONTRACT_BSC=
STAKING_CONTRACT_BSC_TEST=
STAKING_CONTRACT_ETH=
STAKING_CONTRACT_POLYGON=

# USDT contract addresses (defaults already set in config/blockchain.php — only override if needed)
# USDT_BSC_ADDRESS=0x55d398326f99059fF775485246999027B3197955
# USDT_BSC_TEST_ADDRESS=0x337610d27c682E347C9cD60BD4b3b107C9d34eDd
# USDT_ETH_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
# USDT_POLYGON_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F

# OBX token metadata (name, logo, decimals) are configured via:
# Admin Panel > Settings > OBXCoin Send Settings
# You do NOT need to set these in .env.

# Admin hot-wallet private key — used to sign presale admin transactions (addPhase, fundPresale, etc.)
# NEVER commit this value. Keep it out of source control.
OWNER_PRIVATE_KEY=

# Block explorer API keys (for contract verification and event polling)
BSCSCAN_API_KEY=
# ETHERSCAN_API_KEY=
# POLYGONSCAN_API_KEY=

# Block to start scanning for TokensPurchased events (set to your deployment block number)
PRESALE_START_BLOCK=0

# Webhook & API security tokens
# HMAC-SHA256 secret for on-chain event webhooks (generate with: openssl rand -hex 32)
PRESALE_WEBHOOK_SECRET=
# Bearer token for cron sync endpoint
PRESALE_SYNC_API_KEY=

# =============================================================================
# WalletConnect (for direct on-chain USDT → OBX purchase)
# Get a Project ID at https://cloud.walletconnect.com
# =============================================================================
# (These are stored in admin_settings table, not .env.
#  Set them in the Admin Panel → Settings → Payment → WalletConnect.)
# walletconnect_enabled       = 1
# walletconnect_project_id    = your-project-id
# walletconnect_chain_id      = 56

# =============================================================================
# NOWPayments (crypto payment processor — any coin → OBX)
# API key and IPN secret from https://nowpayments.io
# =============================================================================
# (Stored in admin_settings table → Admin Panel → Settings → Payment → NOWPayments)
# nowpayments_enabled         = 1
# nowpayments_api_key         = ...
# nowpayments_ipn_secret      = ...
# nowpayments_sandbox         = 0

# =============================================================================
# Hardhat deployment helpers (only needed when running deploy scripts locally)
# =============================================================================
# TREASURY_ADDRESS=            # Wallet to receive USDT from presale sales
# PRESALE_ALLOCATION=60000000  # OBX tokens to send to presale contract
# INITIAL_SUPPLY=100000000     # Total OBX supply
